# =============================================================================
# Seele 环境变量配置
# =============================================================================
# 能力的植入方式：通过 .env 指定 YAML 相对路径，YAML 文件位于宿主机，
# 修改 YAML 后重启服务即可热插拔能力，无需重新挂载或重建镜像。
# =============================================================================

# ── 工具注册表 ────────────────────────────────────────────────────
# MultiAgent CLI / Workflow Agent 使用的工具注册表路径
REGISTRY_PATH=G:\Program\go\Seele\model_agent\registries\registry_host.yaml

# ── MySQL 数据库沙盒 ──────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASS=Hzr040622
MYSQL_DB=seele

# ── Python 脚本沙盒 ──────────────────────────────────────────────
SCRIPT_WORK_DIR=G:\Program\go\Seele\model_agent\sandbox
SCRIPT_TIMEOUT_SEC=30

# ── 宿主机命令行沙盒 ──────────────────────────────────────────────
SHELL_WORK_DIR=G:\Program\go\Seele
SHELL_TIMEOUT_SEC=60
SHELL_AUTO_APPROVE=true

# ── 博查 Web Search ────────────────────────────────────────────────
BOCHA_API_KEY=sk-d33ab69f20e8466fb950f7e819f2c6c7
BOCHA_API_ENDPOINT=https://api.bocha.cn/v1/web-search
BOCHA_MAX_RESULTS=10
BOCHA_TIMEOUT_SEC=15

# ── 技能生成目录 ──────────────────────────────────────────────────
TOOLS_DIR=G:\Program\go\Seele\example_tools